      "parameters": {
        "jsCode": "function safeJson(v, fallback) {\n  if (v == null) return fallback;\n  if (typeof v === \"object\") return v;\n  if (typeof v !== \"string\") return fallback;\n\n  try {\n    return JSON.parse(v);\n  } catch {\n    return fallback;\n  }\n}\n\nconst row = $node[\"Persistent Session State Retrieval\"]?.json ?? {};\nconst sessionId = String($json.sessionId ?? \"\").trim();\n\nconst oldFacts = safeJson(row.facts, {});\nlet oldAsked = safeJson(row.asked_history, []);\nif (!Array.isArray(oldAsked)) oldAsked = [];\n\nreturn [{\n  json: {\n    ...$json,\n    sessionId,\n    row_exists: !!row.id,\n    rowId: row.id ?? null,\n    oldFacts,\n    oldAsked,\n  }\n}];"
      },
