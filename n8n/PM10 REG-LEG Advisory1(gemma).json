        "jsCode": "const facts = $json.facts ?? {};\n\nconst role = facts.user_role?.value ?? \"UNKNOWN\";\nconst activity = facts.activity_type?.value ?? \"UNKNOWN\";\nconst sensitive = facts.sensitive_group?.value ?? \"UNKNOWN\";\nconst pm = $json.pm_level_code ?? \"UNKNOWN\";\n\nlet rule = {\n  rule_id: \"REG_PM_DEFAULT\",\n  source: \"환경부/에어코리아 미세먼지 행동요령\",\n  action_list: [\"CAUTION\"]\n};\n\nif (pm === \"VERY_BAD\") {\n  if (sensitive === \"TRUE\") {\n    rule = {\n      rule_id: \"REG_PM_01\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"INDOOR_RECOMMENDED\", \"CONSULT_DOCTOR_IF_OUTDOOR\", \"WEAR_MASK\"]\n    };\n  } else {\n    rule = {\n      rule_id: \"REG_PM_02\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"LIMIT_OUTDOOR_ACTIVITY\", \"WEAR_MASK\"]\n    };\n  }\n\n  if ([\"PE_CLASS\", \"OUTDOOR_CLASS\", \"OUTDOOR_PLAY\", \"EXERCISE\"].includes(activity)) {\n    rule = {\n      rule_id: \"REG_PM_03\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"STOP_OUTDOOR_ACTIVITY\", \"WEAR_MASK\"]\n    };\n  }\n\n  if (role === \"WORKER\" && activity === \"OUTDOOR_WORK\") {\n    rule = {\n      rule_id: \"REG_PM_04\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"PROTECTIVE_MEASURES_REQUIRED\", \"WEAR_MASK\"]\n    };\n  }\n}\nelse if (pm === \"BAD\") {\n  if (sensitive === \"TRUE\") {\n    rule = {\n      rule_id: \"REG_PM_05\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"LIMIT_OUTDOOR_ACTIVITY\", \"WEAR_MASK\"]\n    };\n  } else {\n    rule = {\n      rule_id: \"REG_PM_06\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"LIMIT_OUTDOOR_ACTIVITY\", \"WEAR_MASK\"]\n    };\n  }\n\n  if (role === \"TEACHER\" && [\"PE_CLASS\", \"OUTDOOR_CLASS\"].includes(activity)) {\n    rule = {\n      rule_id: \"REG_PM_07\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"SWITCH_TO_INDOOR\"]\n    };\n  }\n\n  if (role === \"PARENT\" && activity === \"OUTDOOR_PLAY\") {\n    rule = {\n      rule_id: \"REG_PM_08\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"LIMIT_CHILD_OUTDOOR\"]\n    };\n  }\n}\nelse if (pm === \"NORMAL\") {\n  if (sensitive === \"TRUE\") {\n    rule = {\n      rule_id: \"REG_PM_09A\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"CAUTION_SENSITIVE\"]\n    };\n  } else {\n    rule = {\n      rule_id: \"REG_PM_09\",\n      source: \"환경부/에어코리아 미세먼지 행동요령\",\n      action_list: [\"CAUTION\"]\n    };\n  }\n}\nelse if (pm === \"GOOD\") {\n  rule = {\n    rule_id: \"REG_PM_10\",\n    source: \"환경부/에어코리아 미세먼지 행동요령\",\n    action_list: [\"NORMAL_ACTIVITY\"]\n  };\n}\n\nreturn [{ json: { ...$json, rule } }];"
      },
