    {
      "parameters": {
        "jsCode": "const oldFacts = $json.oldFacts ?? {};\nconst oldAsked = $json.oldAsked ?? [];\n\nconst newFacts = $json.output?.facts ?? $json.facts ?? {};\n\nconst mergedFacts = { ...oldFacts };\n\nfor (const [key, value] of Object.entries(newFacts)) {\n  if (value && value.value && value.value !== \"UNKNOWN\") {\n    mergedFacts[key] = value;\n  } else if (!mergedFacts[key]) {\n    mergedFacts[key] = value;\n  }\n}\n\nreturn [{\n  json: {\n    ...$json,\n    facts: mergedFacts,\n    asked_history: oldAsked,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1216,
        -80
      ],
      "id": "92d88ff4-7e77-4c6f-b245-8315ce8d630a",
      "name": "State Evidence Accumulation"
    },
    {
      "parameters": {
        "jsCode": "const facts = $json.facts ?? {};\n\nconst requiredBeforePrediction = [\n  \"user_role\",\n  \"activity_type\",\n  \"sensitive_group\",\n  \"region\"\n];\n\nconst missing = [];\n\nconst asked = Array.isArray($json.oldAsked) ? $json.oldAsked : [];\n\nfor (const key of requiredBeforePrediction) {\n  if (!facts[key] || !facts[key].value || facts[key].value === \"UNKNOWN\") {\n    if (!asked.includes(key)) {\n      missing.push(key);\n    }\n  }\n}\n\nconst questions = {\n  user_role: \"학부모, 학생, 교사, 직장인 중 어떤 상황인가요?\",\n  activity_type: \"어떤 활동과 관련된 건가요? 체육수업, 야외활동, 출근, 야외근무 중 어떤 건가요?\",\n  sensitive_group: \"미세먼지에 민감한 편인가요? 예: 어린이, 노약자, 천식 등\",\n  region: \"서울 어느 지역 기준으로 볼까요? 예: 서울 중구, 서울 관악구\"\n};\n\nconst ready_for_prediction = missing.length === 0;\n\nreturn [{\n  json: {\n    ...$json,\n    next_key: ready_for_prediction ? null : missing[0],\n    ready_for_prediction,\n    missing,\n    next_question: ready_for_prediction ? null : questions[missing[0]]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        -80
      ],
      "id": "c8c28f5b-c713-4aa2-8916-e329dce60d6c",
