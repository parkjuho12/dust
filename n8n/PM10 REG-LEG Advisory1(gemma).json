    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"additionalProperties\": false,\n  \"required\": [\"facts\"],\n  \"properties\": {\n    \"facts\": {\n      \"type\": \"object\",\n      \"additionalProperties\": false,\n      \"properties\": {\n        \"user_role\": {\n          \"type\": \"object\",\n          \"required\": [\"value\"],\n          \"properties\": {\n            \"value\": { \"type\": \"string\", \"enum\": [\"PARENT\",\"STUDENT\",\"TEACHER\",\"WORKER\",\"UNKNOWN\"] },\n            \"evidence\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n            \"confidence\": { \"type\": \"number\", \"minimum\": 0, \"maximum\": 1 }\n          }\n        },\n        \"activity_type\": {\n          \"type\": \"object\",\n          \"required\": [\"value\"],\n          \"properties\": {\n            \"value\": { \"type\": \"string\", \"enum\": [\"COMMUTE\",\"PE_CLASS\",\"OUTDOOR_CLASS\",\"OUTDOOR_WORK\",\"OUTDOOR_PLAY\",\"EXERCISE\",\"UNKNOWN\"] },\n            \"evidence\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n            \"confidence\": { \"type\": \"number\", \"minimum\": 0, \"maximum\": 1 }\n          }\n        },\n        \"sensitive_group\": {\n          \"type\": \"object\",\n          \"required\": [\"value\"],\n          \"properties\": {\n            \"value\": { \"type\": \"string\", \"enum\": [\"TRUE\",\"FALSE\",\"UNKNOWN\"] },\n            \"evidence\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n            \"confidence\": { \"type\": \"number\", \"minimum\": 0, \"maximum\": 1 }\n          }\n        },\n        \"region\": {\n          \"type\": \"object\",\n          \"required\": [\"value\"],\n          \"properties\": {\n            \"value\": { \"type\": \"string\" },\n            \"evidence\": { \"type\": \"array\", \"items\": { \"type\": \"string\" } },\n            \"confidence\": { \"type\": \"number\", \"minimum\": 0, \"maximum\": 1 }\n          }\n        }\n      }\n    }\n  }\n}",
        "autoFix": true
      },
