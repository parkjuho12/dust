      "parameters": {
        "jsCode": "const actions = Array.isArray($json.decision) ? $json.decision : [];\n\nconst pmCode = $json.pm_level_code || \"UNKNOWN\";\n\n// 여기만 바꿔\nconst role = $json.user_role || \"UNKNOWN\";\nconst activity = $json.activity_type || \"UNKNOWN\";\nconst sensitive = $json.sensitive_group || \"UNKNOWN\";\nconst region = $json.region || $json.requested_region || \"\";\n\nlet messages = [];\n\n// 1. 상태 설명\nif (pmCode === \"GOOD\") {\n  messages.push(\n    region\n      ? `${region} 기준으로 보면 공기질은 전반적으로 양호한 상태로 예상됩니다.`\n      : \"현재 예측으로는 공기질이 전반적으로 양호한 상태입니다.\"\n  );\n} else if (pmCode === \"NORMAL\") {\n  messages.push(\n    region\n      ? `${region} 기준으로 보면 공기질은 비교적 안정적인 수준으로 예상됩니다.`\n      : \"현재 예측으로는 공기질이 비교적 안정적인 수준입니다.\"\n  );\n} else if (pmCode === \"BAD\") {\n  messages.push(\n    region\n      ? `${region} 기준으로 보면 공기질이 다소 나쁜 수준으로 예상됩니다.`\n      : \"현재 공기질이 다소 나쁜 수준으로 예상됩니다.\"\n  );\n} else if (pmCode === \"VERY_BAD\") {\n  messages.push(\n    region\n      ? `${region} 기준으로 보면 공기질이 매우 나쁜 상태로 예상됩니다.`\n      : \"현재 공기질이 매우 나쁜 상태로 예상됩니다.\"\n  );\n} else {\n  messages.push(\"현재 공기질 상태를 해석 중입니다.\");\n}\n\n// 2. 사용자 조건 반영\nif (sensitive === \"TRUE\") {\n  messages.push(\"천식 등 호흡기 민감군의 경우 일반인보다 영향을 더 받을 수 있습니다.\");\n}\n\nif (role === \"WORKER\" && activity === \"OUTDOOR_WORK\") {\n  messages.push(\"야외 근무 환경에서는 미세먼지 노출이 더 클 수 있습니다.\");\n}\n\nif (role === \"TEACHER\" && [\"PE_CLASS\", \"OUTDOOR_CLASS\"].includes(activity)) {\n  messages.push(\"야외 수업 상황에서는 학생들의 노출을 더 신중하게 볼 필요가 있습니다.\");\n}\n\nif (role === \"PARENT\" && activity === \"OUTDOOR_PLAY\") {\n  messages.push(\"아이의 야외 활동은 상황에 맞게 조절하는 것이 좋습니다.\");\n}\n\n// 3. 행동 제시\nif (actions.includes(\"STOP_OUTDOOR_ACTIVITY\")) {\n  messages.push(\"야외 활동을 중단하고 실내 활동으로 전환하세요.\");\n}\nif (actions.includes(\"LIMIT_OUTDOOR_ACTIVITY\")) {\n  messages.push(\"장시간 또는 무리한 실외활동은 줄이세요.\");\n}\nif (actions.includes(\"INDOOR_RECOMMENDED\")) {\n  messages.push(\"가급적 실내 활동 위주로 하세요.\");\n}\nif (actions.includes(\"WEAR_MASK\")) {\n  messages.push(\"외출 시 보건용 마스크 착용을 권장합니다.\");\n}\nif (actions.includes(\"CONSULT_DOCTOR_IF_OUTDOOR\")) {\n  messages.push(\"외출이 필요하다면 의료진과 상담을 고려하세요.\");\n}\nif (actions.includes(\"SWITCH_TO_INDOOR\")) {\n  messages.push(\"야외 활동은 실내 활동으로 대체하는 것이 좋습니다.\");\n}\nif (actions.includes(\"PROTECTIVE_MEASURES_REQUIRED\")) {\n  messages.push(\"야외 작업 시 보호 장비를 반드시 착용하세요.\");\n}\nif (actions.includes(\"LIMIT_CHILD_OUTDOOR\")) {\n  messages.push(\"아이의 야외 활동 시간을 줄이세요.\");\n}\nif (actions.includes(\"CAUTION\")) {\n  messages.push(\"현재 상태를 보면서 무리하지 않는 범위에서 활동하세요.\");\n}\nif (actions.includes(\"CAUTION_SENSITIVE\")) {\n  messages.push(\"무리한 실외활동은 피하고 몸 상태를 보며 활동하세요.\");\n}\nif (actions.includes(\"NORMAL_ACTIVITY\")) {\n  messages.push(\"일반적인 야외 활동이 가능합니다.\");\n}\n\n// 4. 마지막 fallback\nif (actions.length === 0) {\n  if (sensitive === \"TRUE\") {\n    messages.push(\"몸 상태를 보며 무리하지 않는 선에서 활동하세요.\");\n  } else {\n    messages.push(\"현재 상태를 보면서 활동하세요.\");\n  }\n}\n\nconst finalMessage = messages.join(\" \");\n\nreturn [{\n  json: {\n    ...$json,\n    reply: finalMessage,\n    message: finalMessage,\n    leg_message: finalMessage  // 추가\n  }\n}];"
      },
